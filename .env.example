# ─── LLM (provider-agnostic) ───
LLM_PROVIDER=openai                    # "openai" or "anthropic"
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GENERATION_MODEL=gpt-4o                # or claude-sonnet-4-6-20250514
EDITORIAL_MODEL=gpt-4o                 # or claude-opus-4-6-20250514
LANGSMITH_API_KEY=ls-...
LANGSMITH_PROJECT=amber-content-engine

# ─── Database ───
DATABASE_URL=postgresql+psycopg://amber:password@localhost:5432/amber_content

# ─── Scraping ───
FIRECRAWL_API_KEY=fc-...

# ─── Google (Sheets + Docs) ───
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
GOOGLE_MASTER_SHEET_ID=your-sheet-id

# ─── Slack ───
SLACK_BOT_TOKEN=xoxb-...
SLACK_REVIEW_CHANNEL=content-review
SLACK_ESCALATION_CHANNEL=content-escalation

# ─── LinkedIn (Buffer or native API) ───
LINKEDIN_ACCESS_TOKEN=
BUFFER_ACCESS_TOKEN=

# ─── HubSpot ───
HUBSPOT_API_KEY=

# ─── Scheduling ───
CYCLE_CRON=0 7 */14 * *
TIMEZONE=Europe/London

# ─── Server ───
API_HOST=0.0.0.0
API_PORT=8000
